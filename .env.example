WEIBO_COOKIE="你的微博 Cookie 粘贴在这里"

# ------------------------------------------------------------
# LLM 配置（三选一，取消对应组的注释即可）
# ------------------------------------------------------------

# ① 硅基流动（国内直连，注册 https://cloud.siliconflow.cn）
# LLM_API_KEY  = "sk-xxx"
# LLM_BASE_URL = "https://api.siliconflow.cn/v1"
# LLM_MODEL    = "deepseek-ai/DeepSeek-V3"

# ② 智谱 GLM-4（永久免费，注册 https://open.bigmodel.cn）
# LLM_API_KEY  = "xxx.xxx"
# LLM_BASE_URL = "https://open.bigmodel.cn/api/paas/v4"
# LLM_MODEL    = "glm-4-flash"

# ③ Google Gemini（1500次/天，需翻墙，注册 https://aistudio.google.com）
# LLM_API_KEY  = "AIza..."
# LLM_BASE_URL = "https://generativelanguage.googleapis.com/v1beta/openai"
# LLM_MODEL    = "gemini-2.5-flash"
